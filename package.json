{
  "name": "base.js",
  "version": "0.5.3",
  "apidoc": {
    "title": "Base.js API DOC Browser",
    "url": "http://localhost:3000/v1"
  },
  "description": "Production Application Boilerplate for Server Side.",
  "main": "src/index.js",
  "repository": "https://github.com/jimzhan/base.js",
  "author": "Jim Zhan <jim.zhan@me.com>",
  "license": "Apache-2.0",
  "scripts": {
    "lint": "eslint --ext=.js src test",
    "docs": "apidoc -i src -o docs/ && serve docs",
    "[PROFILES]": "====== Dev server with hotreload supports =======",
    "start": "cross-env NODE_ENV=develop nodemon src/index.js",
    "staging": "cross-env NODE_ENV=staging pm2 start --name staging --interpreter babel-node src/index.js",
    "release": "cross-env NODE_ENV=release pm2 start --name release --interpreter babel-node src/index.js",
    "[VERSION]": "======= Semantic Versioning =======",
    "patch": "npm version patch",
    "postpatch": "npm run push",
    "minor": "npm version minor",
    "postminor": "npm run push",
    "push": "git push --tags && npm publish",
    "[TEST]": "======= Test case runner suites =======",
    "pretest": "npm run lint",
    "test": "mocha --timeout 10000 --require ignore-styles --compilers js:babel-core/register --recursive test/**/*.spec.js src/**/*.spec.js"
  },
  "dependencies": {
    "apidoc": "^0.17.6",
    "assert": "^1.4.1",
    "axios": "^0.16.2",
    "chai": "^4.0.2",
    "cross-env": "^5.0.1",
    "dotenv": "^4.0.0",
    "glob": "^7.1.2",
    "http-status-codes": "^1.1.6",
    "ignore-styles": "^5.0.1",
    "koa": "^2.3.0",
    "koa-body": "^2.3.0",
    "koa-jwt": "^3.2.2",
    "koa-path-match": "^2.0.0",
    "koa-router": "^7.2.1",
    "mocha": "^3.4.2",
    "mongodb": "^2.2.29",
    "supertest": "^3.0.0",
    "winston": "^2.3.1"
  },
  "devDependencies": {
    "babel-cli": "^6.24.1",
    "babel-eslint": "^7.2.3",
    "babel-plugin-module-resolver": "^2.7.1",
    "babel-plugin-transform-runtime": "^6.23.0",
    "babel-preset-env": "^1.5.2",
    "babel-preset-stage-2": "^6.24.1",
    "eslint": "^4.1.1",
    "eslint-config-airbnb-base": "^11.2.0",
    "eslint-import-resolver-babel-module": "^3.0.0",
    "eslint-plugin-html": "^3.0.0",
    "eslint-plugin-import": "^2.6.1",
    "nodemon": "^1.11.0",
    "serve": "^6.0.0"
  }
}
