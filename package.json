{
  "name": "base.js",
  "version": "0.1.0",
  "description": "Production application boilerplate for Koa.js",
  "main": "index.js",
  "repository": "https://github.com/jimzhan/base.js",
  "author": "Jim Zhan <jim.zhan@me.com>",
  "license": "Apache-2.0",
  "babel": {
    "presets": [
      ["env", {
        "targets": {
          "node": "current"
        }
      }],
      "stage-2"
    ],
    "plugins": [
      "transform-class-properties",
      "transform-decorators-legacy",
      "transform-decorators",
      "transform-runtime",
      ["module-resolver", {
        "root": ["./src"],
        "alias": {
          "test": "./test"
        }
      }]
    ],
    "env": {
      "test": {
        "presets": ["env", "stage-2"],
        "plugins": [ "istanbul" ]
      }
    }
  }
}
